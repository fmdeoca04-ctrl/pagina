// ═══════════ ACTIONS ═══════════
function togT(id){if(S.todayIds.includes(id))S.todayIds=S.todayIds.filter(x=>x!==id);save();rBl();rTd();rAy();}
function remT(id){S.todayIds=S.todayIds.filter(x=>x!==id);save();rTd();rBl();rAy();}
function togDone(id){if(S.doneIds.includes(id))S.doneIds=S.doneIds.filter(x=>x!==id);else S.doneIds.push(id);save();rTd();rAy();}
function clearDone(){const d=S.doneIds.filter(id=>S.todayIds.includes(id));S.todayIds=S.todayIds.filter(id=>!d.includes(id));S.doneIds=S.doneIds.filter(id=>!d.includes(id));save();rTd();rBl();rAy();toast('Tareas limpiadas','ok');}
function delT(id){S.tasks=S.tasks.filter(t=>t.id!==id);S.todayIds=S.todayIds.filter(x=>x!==id);S.doneIds=S.doneIds.filter(x=>x!==id);save();rBl();rTd();rAy();}

