function openSetHelper(id,mode='set'){
  activeTaskId = id;
  const t = S.tasks.find(x => x.id === id);
  if(!t) return;
  document.getElementById('help-title').textContent = mode==='add' ? 'Agregar a hoy' : 'Asignar Ayudador';
  document.getElementById('help-list').innerHTML = S.helpers.map(h => 
    `<button class="btn-g" style="flex:1 1 45%; padding:10px; font-size:11px; ${t.h===h.id?'border-color:var(--acc);color:var(--acc);background:var(--acc-l)':''}" onclick="setHelper('${h.id}','${mode}')">
      <span class="hdot" style="background:${h.c}; display:inline-block; margin-right:4px;"></span>${h.lb}
    </button>`
  ).join('');
  document.getElementById('m-help').classList.add('open');
}
function setHelper(hid,mode='set'){
  if(!activeTaskId) return;
  const t = S.tasks.find(x => x.id === activeTaskId);
  if(t){
    t.h = hid;
    if(mode==='add' && !S.todayIds.includes(t.id))S.todayIds.push(t.id);
  }
  save(); rBl(); rTd(); rAy();
  cm('m-help');
  toast(mode==='add'?'Tarea agregada a hoy':'Ayudador actualizado', 'ok');
}

function randColor(){return `hsl(${Math.floor(Math.random()*360)} 70% 45%)`;}
function slugHelper(name){
  let base=name.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z0-9]+/g,'-').replace(/^-+|-+$/g,'').slice(0,18)||'h';
  let id=base,i=2;
  while(S.helpers.some(h=>h.id===id)){id=`${base}-${i}`;i++;}
  return id;
}
function renderHelperConfig(){
  const c=document.getElementById('cfg-helpers-list');if(!c)return;
  c.innerHTML=S.helpers.map(h=>`<div style="display:flex;gap:8px;align-items:center">
      <span class="hdot" style="background:${h.c};width:10px;height:10px;margin-top:0"></span>
      <input class="finp" value="${esc(h.lb)}" oninput="renameHelper('${h.id}',this.value)" ${h.id==='sin'?'disabled':''} />
      ${h.id==='sin'?'':`<button class="btn-g" onclick="removeHelper('${h.id}')" style="padding:8px 10px">✕</button>`}
    </div>`).join('');
}
function addHelper(){
  const inp=document.getElementById('cfg-new-helper');
  const name=inp.value.trim();
  if(!name){toast('Escribí un nombre de ayudador','err');return;}
  const id=slugHelper(name);
  S.helpers.push({id,lb:name,c:randColor()});
  inp.value='';
  save();renderHelperConfig();rBl();rTd();rAy();
  toast('Ayudador agregado','ok');
}
function renameHelper(id,name){
  const h=S.helpers.find(x=>x.id===id);if(!h)return;
  h.lb=name.trim()||h.lb;
  save();rBl();rAy();
}
function removeHelper(id){
  if(id==='sin')return;
  const h=S.helpers.find(x=>x.id===id);if(!h)return;
  if(!confirm(`¿Borrar ayudador "${h.lb}"?`))return;
  S.tasks.forEach(t=>{if(t.h===id)t.h='sin';});
  S.helpers=S.helpers.filter(x=>x.id!==id);
  save();renderHelperConfig();rBl();rTd();rAy();
  toast('Ayudador eliminado','ok');
}

