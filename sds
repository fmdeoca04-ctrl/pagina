  S.cats.push(n);save();rBl();cancelNewCat();toast('Categoría creada','ok');
}
function delCat(cat){
  const tasks=S.tasks.filter(t=>t.cat===cat);
  if(tasks.length&&!confirm(`"${cat}" tiene ${tasks.length} tarea(s). ¿Seguro que querés moverlas a Otros?`))return;
  S.tasks.forEach(t=>{if(t.cat===cat)t.cat='Otros';});
  S.cats=S.cats.filter(c=>c!==cat);save();rBl();rTd();rAy();toast('Categoría eliminada','ok');
}

