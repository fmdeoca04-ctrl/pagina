async function aiClassifyModal(){
  const txt=document.getElementById('at-t').value.trim();if(!txt)return;
  if(!S.cfg.key){toast('Falta API Key de OpenAI en config','err');return;}
  const ai=await doAI(txt);
  if(ai){document.getElementById('aisug').classList.add('show');
    document.getElementById('aicats').innerHTML=[ai.cat,...S.cats.filter(c=>c!==ai.cat).slice(0,3)].map(c=>
      `<div class="aic${c===ai.cat?' sel':''}" onclick="pickCat('${esc(c)}',this)">${c}</div>`).join('');
    document.getElementById('aihs').innerHTML=S.helpers.filter(h=>h.id===ai.h||h.id==='sin').slice(0,5).map(h=>
      `<div class="aic${h.id===ai.h?' sel':''}" onclick="pickHel('${h.id}',this)">${h.lb}</div>`).join('');
    document.getElementById('at-c').value=ai.cat;document.getElementById('at-h').value=ai.h;}
}
async function doAI(txt){
  if(!S.cfg.key)return null;
  const p=`Clasificá esta tarea para una empresa de servicios tecnológicos.\nCategorías: ${S.cats.join(', ')}\nAyudadores (id→nombre):\n${S.helpers.map(h=>h.id+': '+h.lb).join('\n')}\nTarea: "${txt}"\nRespondé SOLO con JSON: {"cat":"...","h":"..."}\nUsá exactamente los nombres/IDs listados.`;
  try{const r=await fetch('https://api.openai.com/v1/chat/completions',{method:'POST',
    headers:{'Content-Type':'application/json','Authorization':'Bearer '+S.cfg.key},
    body:JSON.stringify({model:S.cfg.model||'gpt-4o-mini',messages:[{role:'user',content:p}],temperature:0.1,max_tokens:60})});
    const d=await r.json();if(d.error)throw new Error(d.error.message);
    return JSON.parse(d.choices[0].message.content.trim().replace(/```json|```/g,''));
  }catch(e){toast('Error IA: '+e.message,'err');return null;}
}

// ═══════════ SYNC TELEGRAM ═══════════
async function syncTelegram(){
  if(!S.cfg.sheetUrl){toast('Falta URL del Google Sheet en ⚙','err');openCfg();return;}
  toast('Sincronizando bot...','');
  try{
    const r=await fetch(S.cfg.sheetUrl);
    if(!r.ok)throw new Error('No se pudo acceder al Sheet');
    const csv=await r.text();
    const lines=csv.split('\n').filter(l=>l.trim());
    if(lines.length<2){toast('Sin tareas nuevas del bot','ok');return;}
    
    let added=0;
    const existingTexts=new Set(S.tasks.map(t=>t.text.toLowerCase().trim()));
    
    for(let i=1;i<lines.length;i++){
      const cols=parseCSVLine(lines[i]);
      if(cols.length<3)continue;
      
      const text=(cols[2]||'').trim();
      if(!text)continue;
      if(existingTexts.has(text.toLowerCase()))continue;
      
      const cat=(cols[3]||'Chatbot').trim();
      const h=(cols[4]||'sin').trim();
      const finalCat = S.cats.includes(cat) ? cat : 'Chatbot';
      const finalH = S.helpers.some(x=>x.id===h) ? h : 'sin';
      S.tasks.push({id:'tg'+Date.now()+'_'+i,text,cat:finalCat,h:finalH});
      existingTexts.add(text.toLowerCase());
      added++;
    }
    
    if(added>0){
      save();rBl();rTd();rAy();
      toast(`${added} tarea${added>1?'s':''} sincronizada${added>1?'s':''}`,'ok');
    } else {
      toast('Todo al día con el bot','ok');
    }
  }catch(e){
    toast('Error sync: '+e.message,'err');
  }
}
function parseCSVLine(line){
  const r=[];let cur='';let inQ=false;
  for(let i=0;i<line.length;i++){
    const c=line[i];
    if(c==='"'){if(inQ&&line[i+1]==='"'){cur+='"';i++;}else{inQ=!inQ;}}
    else if(c===','&&!inQ){r.push(cur);cur='';}
    else{cur+=c;}
  }
  r.push(cur);return r;
}

