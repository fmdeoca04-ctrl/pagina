function showNewCat(){document.getElementById('new-cat-row').classList.add('show');document.getElementById('new-cat-inp').value='';document.getElementById('new-cat-inp').focus();}
function cancelNewCat(){document.getElementById('new-cat-row').classList.remove('show');}
function confirmNewCat(){
  const n=document.getElementById('new-cat-inp').value.trim();
