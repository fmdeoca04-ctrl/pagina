function saveCfg(){S.cfg.key=document.getElementById('cfg-k').value.trim();S.cfg.model=document.getElementById('cfg-m').value;S.cfg.sheetUrl=document.getElementById('cfg-sheet').value.trim();save();cm('mcfg');toast('Configuración guardada','ok');}
function cm(id){document.getElementById(id).classList.remove('open');}
document.querySelectorAll('.overlay').forEach(o=>o.addEventListener('click',e=>{if(e.target===o)o.classList.remove('open');}));
function expJSON(){const b=new Blob([JSON.stringify(S,null,2)],{type:'application/json'});const a=document.createElement('a');a.href=URL.createObjectURL(b);a.download='planificador_backup.json';a.click();toast('Backup descargado','ok');}
function impJSON(e){const f=e.target.files[0];if(!f)return;const fr=new FileReader();fr.onload=ev=>{try{S={...S,...JSON.parse(ev.target.result)};if(!S.cats)S.cats=[...DEFAULT_CATS];if(!Array.isArray(S.helpers)||!S.helpers.length)S.helpers=[...DEFAULT_HELPERS];if(!S.helpers.find(h=>h.id==='sin'))S.helpers.push({id:'sin',lb:'Sin ayudador',c:'#9ca3af'});const valid=new Set(S.helpers.map(h=>h.id));S.tasks.forEach(t=>{if(!valid.has(t.h))t.h='sin';});save();rBl();rTd();rAy();toast('Backup restaurado','ok');}catch{toast('Error en el archivo','err');}};fr.readAsText(f);}
function toast(msg,type=''){const c=document.getElementById('toasts');const t=document.createElement('div');t.className='tst '+(type==='ok'?'ok':type==='err'?'err':'');
t.innerHTML=type==='ok'?'<span style="font-size:14px">✓</span> '+msg:type==='err'?'<span style="font-size:14px">✕</span> '+msg:'<span style="font-size:14px">↻</span> '+msg;
c.appendChild(t);setTimeout(()=>{t.style.opacity='0';t.style.transition='opacity .3s';setTimeout(()=>t.remove(),300);},2500);}
